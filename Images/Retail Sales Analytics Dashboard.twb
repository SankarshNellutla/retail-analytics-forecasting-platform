      <aliases enabled='yes' />
      <column caption='SALES' datatype='real' name='[Calculation_5092023069172649985]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales])' />
      </column>
      <column caption='PROFIT' datatype='real' name='[Calculation_5092023069173284866]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([profit])' />
      </column>
      <column caption='PROFIT RATIO' datatype='real' name='[Calculation_5092023069173407747]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF SUM([sales]) != 0 THEN SUM([profit]) / SUM([sales]) END' />
      </column>
      <column caption='Year on Year Sales %' datatype='real' name='[Calculation_5092023069183807502]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF LOOKUP(SUM([sales]), -12) != 0 THEN (SUM([sales]) - LOOKUP(SUM([sales]), -12)) / LOOKUP(SUM([sales]), -12) END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Last Order Date per Customer' datatype='date' name='[Calculation_5092023069202034717]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{ FIXED [customer_key] : MAX([full_date]) }' />
      </column>
      <column caption='Recency (days)' datatype='integer' name='[Calculation_5092023069202161694]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [Calculation_5092023069202034717], TODAY())' />
      </column>
      <column caption='Frequency (orders)' datatype='integer' name='[Calculation_5092023069202259999]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [customer_key] : COUNTD([order_key]) }' />
      </column>
      <column caption='Monetary' datatype='real' name='[Calculation_5092023069202341920]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [customer_key] : SUM([sales]) }' />
      </column>
      <column caption='R_Score' datatype='integer' name='[Calculation_5092023069202501665]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_5092023069202161694] &lt;= 30 THEN 5&#10;ELSEIF [Calculation_5092023069202161694] &lt;= 60 THEN 4&#10;ELSEIF [Calculation_5092023069202161694] &lt;= 120 THEN 3&#10;ELSEIF [Calculation_5092023069202161694] &lt;= 365 THEN 2&#10;ELSE 1 END' />
      </column>
      <column caption='F_Score' datatype='integer' name='[Calculation_5092023069202608162]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_5092023069202259999] &gt;= 50 THEN 5&#10;ELSEIF [Calculation_5092023069202259999] &gt;= 20 THEN 4&#10;ELSEIF [Calculation_5092023069202259999] &gt;= 10 THEN 3&#10;ELSEIF [Calculation_5092023069202259999] &gt;= 2 THEN 2&#10;ELSE 1 END' />
      </column>
      <column caption='M_Score' datatype='integer' name='[Calculation_5092023069202714659]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_5092023069202341920] &gt;= 10000 THEN 5&#10;ELSEIF [Calculation_5092023069202341920] &gt;= 5000 THEN 4&#10;ELSEIF [Calculation_5092023069202341920] &gt;= 2000 THEN 3&#10;ELSEIF [Calculation_5092023069202341920] &gt;= 500 THEN 2&#10;ELSE 1 END' />
      </column>
      <column caption='RFM_Score' datatype='integer' name='[Calculation_5092023069202780196]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT([Calculation_5092023069202501665]) * 100 + INT([Calculation_5092023069202608162]) * 10 + INT([Calculation_5092023069202714659])' />
      </column>
