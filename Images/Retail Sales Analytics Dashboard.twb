          <formatted-text>
            <run fontcolor='#4e79a7' fontname='Toppan Bunkyu Midashi Gothic'>Sales Trends</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='fact_sales+ (superstore_db)' name='federated.0nccag806ywf2p1a4ku90133vkiu' />
          </datasources>
          <datasource-dependencies datasource='federated.0nccag806ywf2p1a4ku90133vkiu'>
            <column caption='SALES' datatype='real' name='[Calculation_5092023069172649985]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([sales])' />
            </column>
            <column caption='Year on Year Sales %' datatype='real' name='[Calculation_5092023069183807502]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF LOOKUP(SUM([sales]), -12) != 0 THEN (SUM([sales]) - LOOKUP(SUM([sales]), -12)) / LOOKUP(SUM([sales]), -12) END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Category' datatype='string' name='[category]' role='dimension' type='nominal' />
            <column caption='Month' datatype='integer' name='[month]' role='dimension' type='quantitative' />
            <column-instance column='[category]' derivation='None' name='[none:category:nk]' pivot='key' type='nominal' />
            <column-instance column='[month]' derivation='None' name='[none:month:qk]' pivot='key' type='quantitative' />
            <column-instance column='[quarter]' derivation='None' name='[none:quarter:qk]' pivot='key' type='quantitative' />
            <column-instance column='[region]' derivation='None' name='[none:region:nk]' pivot='key' type='nominal' />
            <column-instance column='[segment]' derivation='None' name='[none:segment:nk]' pivot='key' type='nominal' />
            <column-instance column='[year]' derivation='None' name='[none:year:qk]' pivot='key' type='quantitative' />
            <column caption='Quarter' datatype='integer' name='[quarter]' role='dimension' type='quantitative' />
            <column caption='Region' datatype='string' name='[region]' role='dimension' type='nominal' />
            <column caption='Sales' datatype='real' name='[sales]' role='measure' type='quantitative' />
            <column caption='Segment' datatype='string' name='[segment]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_5092023069172649985]' derivation='User' name='[usr:Calculation_5092023069172649985:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_5092023069183807502]' derivation='User' name='[usr:Calculation_5092023069183807502:qk]' pivot='key' type='quantitative'>
              <table-calc ordering-type='Rows' />
            </column-instance>
            <column-instance column='[Calculation_5092023069172649985]' derivation='User' name='[win:usr:Calculation_5092023069172649985:qk]' pivot='key' type='quantitative'>
              <table-calc aggregation='Avg' from='-2' ordering-type='Rows' to='0' type='WindowTotal' window-options='IncludeCurrent' />
            </column-instance>
            <column caption='Year' datatype='integer' name='[year]' role='dimension' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.0nccag806ywf2p1a4ku90133vkiu].[:Measure Names]'>
            <groupfilter function='member' level='[:Measure Names]' member='&quot;[federated.0nccag806ywf2p1a4ku90133vkiu].[usr:Calculation_5092023069183807502:qk]&quot;' user:op='manual' />
          </filter>
          <filter class='categorical' column='[federated.0nccag806ywf2p1a4ku90133vkiu].[none:category:nk]'>
            <groupfilter function='level-members' level='[none:category:nk]' user:ui-enumeration='all' user:ui-marker='enumerate' />
          </filter>
          <filter class='categorical' column='[federated.0nccag806ywf2p1a4ku90133vkiu].[none:region:nk]'>
            <groupfilter function='union' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate'>
              <groupfilter function='member' level='[none:region:nk]' member='&quot;Central&quot;' />
              <groupfilter function='member' level='[none:region:nk]' member='&quot;East&quot;' />
              <groupfilter function='member' level='[none:region:nk]' member='&quot;South&quot;' />
              <groupfilter function='member' level='[none:region:nk]' member='&quot;West&quot;' />
