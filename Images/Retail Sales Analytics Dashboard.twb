      <table>
        <view>
          <datasources>
            <datasource caption='fact_sales+ (superstore_db)' name='federated.0nccag806ywf2p1a4ku90133vkiu' />
          </datasources>
          <datasource-dependencies datasource='federated.0nccag806ywf2p1a4ku90133vkiu'>
            <column caption='PROFIT' datatype='real' name='[Calculation_5092023069173284866]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([profit])' />
            </column>
            <column caption='PROFIT RATIO' datatype='real' name='[Calculation_5092023069173407747]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF SUM([sales]) != 0 THEN SUM([profit]) / SUM([sales]) END' />
            </column>
            <column caption='Category' datatype='string' name='[category]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_5092023069173407747]' derivation='User' name='[cum:usr:Calculation_5092023069173407747:qk]' pivot='key' type='quantitative'>
              <table-calc aggregation='Sum' ordering-type='Rows' type='CumTotal' />
            </column-instance>
            <column-instance column='[category]' derivation='None' name='[none:category:nk]' pivot='key' type='nominal' />
            <column-instance column='[region]' derivation='None' name='[none:region:nk]' pivot='key' type='nominal' />
            <column caption='Profit' datatype='real' name='[profit]' role='measure' type='quantitative' />
